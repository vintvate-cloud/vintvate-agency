generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  image     String?
  author    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String         @id @default(cuid())
  title       String
  description String
  image       String?
  link        String?        // Live link
  tags        String?
  envVars     String?        @db.Text
  type        String         @default("CLIENT") // CLIENT or TEMPLATE

  // Agency Management Fields
  status      String         @default("PLANNED") // PLANNED, PROGRESS, COMPLETED, PAUSED
  budget      Float?         @default(0)
  startDate   DateTime?      @default(now())
  endDate     DateTime?      

  clientId    String?
  client      ClientProfile? @relation(fields: [clientId], references: [id])
  payments    Payment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  description String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model ClientProfile {
  id        String    @id @default(cuid())
  name      String
  email     String?
  company   String?
  phone     String?
  notes     String?   @db.Text
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
